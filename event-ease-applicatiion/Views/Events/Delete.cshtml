@model event_ease_applicatiion.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="delete-page-wrapper">
    <div class="delete-card animate-fade-up">
        <div class="card-header text-center py-4">
            <h2 class="mb-2 text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Delete Event
            </h2>
            <p class="text-muted mb-0">This action cannot be undone.</p>
        </div>

        <div class="card-body p-4 p-md-5">
            <h4 class="mb-4 gradient-text">@Model?.EventName</h4>

            <div class="event-preview mb-5">
                @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                {
                    <img src="@Model.ImageUrl"
                         alt="@Model.EventName"
                         class="preview-image rounded mb-4"
                         onerror="this.src='https://via.placeholder.com/600x300/161b22/6366f1?text=Image+Not+Found'" />
                }
                else
                {
                    <div class="preview-placeholder mb-4">
                        <i class="bi bi-calendar-event"></i>
                    </div>
                }

                <div class="event-info">
                    <div class="info-item">
                        <i class="bi bi-calendar-event me-3 text-primary"></i>
                        <div>
                            <strong>Date:</strong><br />
                            @(Model?.EventDate.ToString("dddd, dd MMMM yyyy • HH:mm") ?? "Not specified")
                        </div>
                    </div>

                    @if (Model?.Venue != null)
                    {
                        <div class="info-item mt-3">
                            <i class="bi bi-geo-alt-fill me-3 text-accent"></i>
                            <div>
                                <strong>Venue:</strong><br />
                                @Model.Venue.Name
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="description mb-5">
                <h6 class="mb-2">Description</h6>
                <p class="text-muted">
                    @(string.IsNullOrWhiteSpace(Model?.Description)
                                        ? "No description provided." 
                                                : Model.Description)
                </p>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-5 pt-4 border-top border-border">
                <form asp-action="Delete" class="d-inline">
                    <input type="hidden" asp-for="EventId" />
                    <button type="submit" class="btn btn-danger btn-lg px-5 glow-danger">
                        <i class="bi bi-trash-fill me-2"></i> Yes, Delete Event
                    </button>
                </form>

                <a asp-action="Index" class="btn btn-outline-light btn-lg px-5">
                    <i class="bi bi-arrow-left me-2"></i> Cancel / Back to List
                </a>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}