@model event_ease_applicatiion.Models.Event

@{
    ViewData["Title"] = "Edit Event";
}

<div class="edit-page-wrapper">
    <div class="form-container animate-fade-up">
        <div class="form-header text-center mb-4">
            <h2 class="mb-1 gradient-text">Edit Event</h2>
            <p class="text-muted small">Update the details for "@Model.EventName"</p>
        </div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-center"></div>

            <!-- Hidden ID -->
            <input type="hidden" asp-for="EventId" />

            <!-- Venue -->
            <div class="mb-3">
                <label asp-for="VenueId" class="form-label"></label>
                <select asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId"></select>
                <span asp-validation-for="VenueId" class="text-danger small"></span>
            </div>

            <!-- Event Name -->
            <div class="mb-3">
                <label asp-for="EventName" class="form-label"></label>
                <input asp-for="EventName" class="form-control" placeholder="e.g. Summer Music Festival" />
                <span asp-validation-for="EventName" class="text-danger small"></span>
            </div>

            <!-- Event Date -->
            <div class="mb-3">
                <label asp-for="EventDate" class="form-label"></label>
                <input asp-for="EventDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="EventDate" class="text-danger small"></span>
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="4"
                          placeholder="Brief description of the event..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Image URL -->
            <div class="mb-4">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control"
                       placeholder="https://example.com/event-poster.jpg" />
                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                <div class="form-text text-muted mt-1 small">
                    Direct link to event poster or cover image
                </div>
            </div>

            <!-- Buttons -->
            <div class="d-flex gap-3 justify-content-center mt-4">
                <button type="submit" class="btn btn-primary btn-lg px-5 glow">
                    Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-light px-4">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}