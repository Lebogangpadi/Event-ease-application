@model event_ease_applicatiion.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="details-page-wrapper">
    <!-- Hero / Cover Image Section -->
    <div class="event-hero">
        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
        {
            <img src="@Model.ImageUrl"
                 alt="@Model.EventName"
                 class="event-hero-image"
                 onerror="this.style.display='none'" />
        }
        else
        {
            <div class="event-hero-placeholder">
                <i class="bi bi-calendar-event-fill"></i>
            </div>
        }

        <div class="event-hero-overlay">
            <div class="container">
                <h1 class="event-title gradient-text">@Model?.EventName</h1>
                <p class="event-date">
                    <i class="bi bi-calendar-event me-2"></i>
                    @if (Model?.EventDate != null)
                    {
                        @Model.EventDate.ToString("dddd, dd MMMM yyyy • HH:mm")
                    }
                    else
                    {
                        <span class="text-muted">Date not specified</span>
                    }
                </p>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="event-details-card animate-fade-up">
                    <div class="card-body p-4 p-md-5">
                        <!-- Description -->
                        <h3 class="mb-4">About this event</h3>
                        <div class="event-description mb-5">
                            @if (!string.IsNullOrEmpty(Model?.Description))
                            {
                                @Html.Raw(Model.Description.Replace("\n", "<br />"))
                            }
                            else
                            {
                                <p class="text-muted fst-italic">No description provided.</p>
                            }
                        </div>

                        <!-- Venue -->
                        @if (Model?.Venue != null)
                        {
                            <div class="venue-info mb-5">
                                <h5 class="mb-3">
                                    <i class="bi bi-geo-alt-fill me-2 text-accent"></i>
                                    Venue
                                </h5>
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(Model.Venue.ImageURL))
                                    {
                                        <img src="@Model.Venue.ImageURL"
                                             alt="@Model.Venue.Name"
                                             class="venue-thumbnail rounded me-3" />
                                    }
                                    <div>
                                        <h6 class="mb-1">@Model.Venue.Name</h6>
                                        @if (!string.IsNullOrEmpty(Model.Venue.Location))
                                        {
                                            <small class="text-muted">@Model.Venue.Location</small>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Action Buttons -->
                        <div class="d-flex flex-wrap gap-3 justify-content-center mt-5 pt-4 border-top border-border">
                            <a asp-action="Edit" asp-route-id="@Model?.EventId"
                               class="btn btn-primary btn-lg px-5 glow">
                                <i class="bi bi-pencil me-2"></i> Edit Event
                            </a>
                            <a asp-action="Index" class="btn btn-outline-light btn-lg px-5">
                                <i class="bi bi-arrow-left me-2"></i> Back to Events
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

