@{
    ViewData["Title"] = "EventEase – Plan Without Stress";
}

<div class="hero-wrapper">
    <div class="container">
        <div class="row align-items-center gy-5 gy-lg-0">

            <!-- Left: Text Content -->
            <div class="col-lg-6 hero-text-side">
                <h1 class="animate-fade-down">
                    Plan Events<br><span class="gradient-text">That Feel Effortless</span>
                </h1>

                <p class="lead animate-fade-up subtitle">
                    Discover beautiful venues • Create memorable events • Book instantly
                </p>

                <div class="cta-buttons animate-fade-up" style="animation-delay: 0.6s;">
                    <a asp-controller="Events" asp-action="Index" class="btn btn-primary btn-lg glow me-3">
                        Browse Events
                    </a>
                    <a asp-controller="Venues" asp-action="Index" class="btn btn-outline-light btn-lg">
                        Find Venues
                    </a>
                </div>
            </div>

            <!-- Right: Image -->
            <div class="col-lg-6 hero-image-side animate-fade-up" style="animation-delay: 0.4s;">
                <div class="hero-image-wrapper">
                    <img src="https://marrymetampabay.com/wp-content/uploads/2021/10/7-1.jpg"
                         alt="Elegant moody event venue with warm candlelight and intimate setup"
                         class="img-fluid hero-image rounded-4 shadow-lg"
                         loading="lazy" />
                </div>
            </div>
        </div>
    </div>

    <!-- Quick stats / trust signals -->
    <div class="trust-bar container animate-fade-up" style="animation-delay: 1s;">
        <div class="row text-center justify-content-center g-4 g-md-5">
            <div class="col-6 col-md-3">
                <div class="stat-number">2.4k+</div>
                <div class="stat-label">Events Hosted</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-number">180+</div>
                <div class="stat-label">Unique Venues</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-number">4.8</div>
                <div class="stat-label">Average Rating</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-number">→ 24h</div>
                <div class="stat-label">Fast Booking</div>
            </div>
        </div>
    </div>
</div>

<!-- Simple features teaser -->
<section class="features-section py-5">
    <div class="container">
        <div class="row justify-content-center text-center mb-5">
            <div class="col-lg-8">
                <h2 class="mb-4 animate-fade">Why choose EventEase?</h2>
                <p class="text-muted lead">Everything you need to turn ideas into unforgettable experiences — without the usual chaos.</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card animate-fade-up">
                    <div class="feature-icon">📍</div>
                    <h5>Curated Venues</h5>
                    <p>Hand-selected spaces for every type of gathering — big or intimate.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card animate-fade-up" style="animation-delay: 0.2s;">
                    <div class="feature-icon">⚡</div>
                    <h5>Instant Confirmation</h5>
                    <p>No endless emails. Book and receive confirmation in seconds.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card animate-fade-up" style="animation-delay: 0.4s;">
                    <div class="feature-icon">🗓️</div>
                    <h5>Smart Tools</h5>
                    <p>Guest lists, schedules, reminders — all in one calm place.</p>
                </div>
            </div>
        </div>
    </div>
</section>
