@model event_ease_applicatiion.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<div class="delete-page-wrapper">
    <div class="delete-card animate-fade-up">
        <div class="card-header text-center py-4 border-bottom border-border">
            <h2 class="mb-2 text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Delete Booking
            </h2>
            <p class="text-muted mb-0 small">
                This action is permanent and cannot be undone.
            </p>
        </div>

        <div class="card-body p-4 p-md-5">
            <!-- Booking Preview -->
            <div class="booking-preview mb-5">
                <h4 class="mb-4 gradient-text">
                    @Model?.Event?.EventName
                </h4>

                <div class="preview-info-grid mb-4">
                    <div class="preview-row">
                        <i class="bi bi-calendar-check-fill me-3 text-primary"></i>
                        <div>
                            <strong>Date & Time:</strong><br />
                            @(Model?.BookingDate.ToString("ddd, dd MMM yyyy • HH:mm") ?? "Not specified")
                        </div>
                    </div>

                    @if (Model?.Venue != null)
                    {
                        <div class="preview-row mt-3">
                            <i class="bi bi-building-fill me-3 text-accent"></i>
                            <div>
                                <strong>Venue:</strong><br />
                                @Model.Venue.Name
                            </div>
                        </div>
                    }
                </div>

                <!-- Venue Image (small preview) -->
                @if (Model?.Venue != null && !string.IsNullOrEmpty(Model.Venue.ImageURL))
                {
                    <img src="@Model.Venue.ImageURL"
                         alt="@Model.Venue.Name"
                         class="venue-preview-image rounded mb-4"
                         onerror="this.src='https://via.placeholder.com/500x280/161b22/6366f1?text=Venue'" />
                }
                else
                {
                    <div class="venue-preview-placeholder mb-4">
                        <i class="bi bi-building"></i>
                    </div>
                }
            </div>

            <!-- Warning -->
            <div class="alert alert-danger text-center mb-5 py-3">
                <strong>Warning:</strong> Deleting this booking will remove the event–venue connection permanently.
            </div>

            <!-- Buttons -->
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-4 pt-3">
                <form asp-action="Delete" class="d-inline">
                    <input type="hidden" asp-for="BookingId" />
                    <button type="submit" class="btn btn-danger btn-lg px-5 glow-danger">
                        <i class="bi bi-trash-fill me-2"></i> Yes, Delete Booking
                    </button>
                </form>

                <a asp-action="Index" class="btn btn-outline-light btn-lg px-5">
                    <i class="bi bi-arrow-left-circle me-2"></i> Cancel / Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}