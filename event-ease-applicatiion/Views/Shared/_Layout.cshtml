<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventEase</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/event_ease_applicatiion.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --bg: #0d1117;
            --bg-card: #161b22;
            --text: #e6edf3;
            --text-muted: #8b949e;
            --border: #30363d;
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --accent: #a78bfa;
        }

        html, body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            /* Fix overlap from fixed navbar */
            padding-top: 30px; /* ← most important fix – adjust if your navbar height changes */
        }

        /* Navbar overrides */
        .navbar {
            background: rgba(13, 17, 23, 0.92) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border) !important;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
            background: linear-gradient(90deg, var(--accent), var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 500;
            transition: all 0.22s ease;
            padding: 0.6rem 1.1rem !important;
            border-radius: 8px;
        }

            .nav-link:hover,
            .nav-link.active {
                color: white !important;
                background: rgba(99, 102, 241, 0.12);
            }

        .navbar-toggler {
            border: 1px solid var(--border);
        }

        .navbar-toggler-icon {
            filter: brightness(0) invert(1);
        }

        main {
            padding: 1.5rem 0 5rem; /* a bit more bottom space is nice */
        }

        .container {
            max-width: 1400px;
        }

        footer {
            background: var(--bg-card);
            border-top: 1px solid var(--border);
            color: var(--text-muted);
            padding: 2.5rem 0;
            font-size: 0.95rem;
        }

            footer a {
                color: var(--text-muted);
                text-decoration: none;
            }

                footer a:hover {
                    color: var(--accent);
                    text-decoration: underline;
                }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #0d1117;
        }

        ::-webkit-scrollbar-thumb {
            background: #30363d;
            border-radius: 5px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #444c56;
            }

        html {
            scroll-behavior: smooth;
        }

        /* ────────────────────────────────────────────────
                   Move shared animations & hero styles HERE so they work on ALL pages
                ──────────────────────────────────────────────── */
        .hero-wrapper {
            position: relative;
            min-height: 90vh;
            display: flex;
            align-items: center;
            padding: 4rem 0 6rem;
            overflow: hidden;
        }

        .hero-background {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #0f0f17 0%, #0a0a12 100%);
            z-index: -2;
        }

            .hero-background::before {
                content: "";
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 20% 30%, rgba(99, 102, 241, 0.12) 0%, transparent 50%);
                z-index: -1;
            }

        /* Animations – now global */
        

        .animate-fade-down {
            animation: fadeDown 1.2s ease-out forwards;
        }

        .animate-fade-up {
            animation: fadeUp 1.1s ease-out forwards;
            opacity: 0; /* start hidden */
        }

        .animate-fade {
            animation: fadeUp 1.3s ease-out forwards;
            opacity: 0;
        }

        .delete-page-wrapper {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .delete-card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 16px;
            max-width: 620px;
            width: 100%;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0,0,0,0.45);
            transition: all 0.3s ease;
        }

            .delete-card:hover {
                box-shadow: 0 12px 50px rgba(220, 38, 38, 0.14);
            }

        .card-header {
            background: rgba(220, 38, 38, 0.07);
        }

        .booking-preview h4 {
            font-weight: 700;
            line-height: 1.2;
        }

        .preview-info-grid {
            font-size: 1.05rem;
            color: #c9d1d9;
        }

        .preview-row {
            display: flex;
            align-items: flex-start;
        }

        .venue-preview-image {
            width: 100%;
            max-height: 260px;
            object-fit: cover;
            border: 1px solid #30363d;
        }

        .venue-preview-placeholder {
            width: 100%;
            height: 220px;
            background: linear-gradient(135deg, #0f0f17, #161b22);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 5rem;
            color: rgba(99, 102, 241, 0.15);
            border-radius: 12px;
            border: 1px solid #30363d;
        }

        .glow-danger {
            box-shadow: 0 0 20px rgba(220, 38, 38, 0.4);
        }

            .glow-danger:hover {
                box-shadow: 0 0 35px rgba(220, 38, 38, 0.6);
                transform: translateY(-2px);
            }

        .btn-danger {
            background: #dc2626;
            border: none;
            font-weight: 600;
        }

            .btn-danger:hover {
                background: #b91c1c;
                transform: translateY(-2px);
            }

        .animate-fade-up {
            animation: fadeUp 0.9s ease-out forwards;
            opacity: 0;
        }

        /* Optional: remove animation on small screens if performance is concern */
        
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
            <div class="container-fluid px-4 px-lg-5">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">EventEase</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Events" asp-action="Index">Events</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Venues" asp-action="Index">Venues</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Bookings" asp-action="Index">Bookings</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Remove or reduce this spacer – padding on body is now handling it -->
    <!-- <div style="height: 80px;"></div>  ← you can delete this line now -->

    <main role="main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top">
        <div class="container text-center">
            © @(DateTime.Now.Year) EventEase •
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>