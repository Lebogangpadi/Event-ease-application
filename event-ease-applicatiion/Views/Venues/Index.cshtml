@model IEnumerable<event_ease_applicatiion.Models.Venue>

@{
    ViewData["Title"] = "Venues Dashboard";
}

<div class="venues-page-wrapper">
    <!-- Header + Create Button -->
    <div class="page-header mb-5">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="mb-1">Venues Overview</h1>
                <p class="text-muted">Manage and explore all available event spaces</p>
            </div>
            <a asp-action="Create" class="btn btn-primary btn-lg glow">
                <i class="bi bi-plus-lg me-2"></i> Add New Venue
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="stats-row row g-4 mb-5">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card animate-fade-up">
                <div class="stat-icon"><i class="bi bi-building"></i></div>
                <div class="stat-value">@Model.Count()</div>
                <div class="stat-label">Total Venues</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card animate-fade-up" style="animation-delay: 0.1s;">
                <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                <div class="stat-value">@Model.Sum(v => v.Capacity)</div>
                <div class="stat-label">Total Capacity</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card animate-fade-up" style="animation-delay: 0.2s;">
                <div class="stat-icon"><i class="bi bi-tags-fill"></i></div>
                <div class="stat-value">@Model.Select(v => v.VenueType?.Name).Distinct().Count()</div>
                <div class="stat-label">Venue Types</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card animate-fade-up" style="animation-delay: 0.3s;">
                <div class="stat-icon"><i class="bi bi-star-fill"></i></div>
                <div class="stat-value">—</div>
                <div class="stat-label">Avg. Rating</div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <h4>No venues found</h4>
            <p>Get started by adding your first venue.</p>
            <a asp-action="Create" class="btn btn-outline-light mt-3">Add Venue</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="venue-card animate-fade-up">
                        <!-- Image -->
                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(item.ImageURL))
                            {
                                <img src="@item.ImageURL"
                                     class="card-img-top"
                                     alt="@item.Name"
                                     loading="lazy"
                                     onerror="this.src='https://via.placeholder.com/600x400/161b22/6366f1?text=No+Image'" />
                            }
                            else
                            {
                                <div class="placeholder-image">
                                    <i class="bi bi-building"></i>
                                </div>
                            }
                        </div>

                        <!-- Content -->
                        <div class="card-body">
                            <h5 class="card-title gradient-text">@item.Name</h5>

                            <div class="venue-meta mb-3">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-geo-alt me-2 text-accent"></i>
                                    <span>@item.Location</span>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-people me-2 text-primary"></i>
                                    <span>Capacity: @(item.Capacity.ToString("N0") ?? "—")</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-tag me-2 text-muted"></i>
                                    <span>@(item.VenueType?.Name ?? "Uncategorized")</span>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="card-footer bg-transparent border-top border-border d-flex justify-content-between">
                            <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-light">
                                <i class="bi bi-eye me-1"></i> Details
                            </a>
                            <div>
                                <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-primary me-2">
                                    <i class="bi bi-pencil me-1"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.VenueId" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash me-1"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
