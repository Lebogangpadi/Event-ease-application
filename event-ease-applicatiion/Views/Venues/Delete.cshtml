@model event_ease_applicatiion.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="delete-page-wrapper">
    <div class="delete-card animate-fade-up">
        <div class="card-header text-center py-4 border-bottom border-border">
            <h2 class="mb-2 text-danger">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Delete Venue
            </h2>
            <p class="text-muted mb-0 small">
                This action is permanent and cannot be undone.
            </p>
        </div>

        <div class="card-body p-4 p-md-5">
            <h4 class="mb-4 gradient-text">@Model?.Name</h4>

            <!-- Venue Preview -->
            <div class="venue-preview mb-5">
                @if (!string.IsNullOrEmpty(Model?.ImageURL))
                {
                    <img src="@Model.ImageURL"
                         alt="@Model.Name"
                         class="preview-image rounded mb-4 shadow-sm"
                         onerror="this.src='https://via.placeholder.com/600x340/161b22/6366f1?text=Image+Not+Found'" />
                }
                else
                {
                    <div class="preview-placeholder mb-4">
                        <i class="bi bi-building"></i>
                    </div>
                }

                <div class="venue-info-grid">
                    <div class="info-row">
                        <i class="bi bi-geo-alt-fill me-3 text-accent"></i>
                        <div>
                            <strong>Location:</strong><br />
                            @Model?.Location
                        </div>
                    </div>
                    <div class="info-row mt-3">
                        <i class="bi bi-people-fill me-3 text-primary"></i>
                        <div>
                            <strong>Capacity:</strong><br />
                            @(Model?.Capacity.ToString("N0") ?? "—") people
                        </div>
                    </div>
                    <div class="info-row mt-3">
                        <i class="bi bi-tags-fill me-3 text-muted"></i>
                        <div>
                            <strong>Type:</strong><br />
                            @(Model?.VenueType?.Name ?? "Not categorized")
                        </div>
                    </div>
                </div>
            </div>

            <!-- Warning & Actions -->
            <div class="alert alert-danger text-center mb-5 py-3">
                <strong>Warning:</strong> Deleting this venue will remove it from all associated events and cannot be recovered.
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-4 pt-3">
                <form asp-action="Delete" class="d-inline">
                    <input type="hidden" asp-for="VenueId" />
                    <button type="submit" class="btn btn-danger btn-lg px-5 glow-danger">
                        <i class="bi bi-trash-fill me-2"></i>Delete Venue
                    </button>
                </form>

                <a asp-action="Index" class="btn btn-outline-light btn-lg px-5">
                    <i class="bi bi-arrow-left-circle me-2"></i> Cancel
                </a>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}